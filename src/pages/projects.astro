---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---
<BaseLayout>
  <div class="page-header">
    <h1>GET /projects</h1>
    <p class="page-subtitle">200 OK · {projects.length} entries</p>
  </div>
  <section class="projects">
    {projects.map((project) => (
      <div class="project">
        <div class="project-header">
          <span class="project-id">[{project.id}]</span>
          <h2 class="project-title">{project.title}</h2>
        </div>
        <p class="project-meta">Description: {project.description}</p>
        <div class="project-stack">
          <p>Stack: </p>
          {project.stack.map((item) => (
            <span class="stack-tag">[{item}]</span>
          ))}
        </div>
        <div class="project-links">
          {project.link && <a href={project.link} class="cta" target="_blank" rel="noopener noreferrer">Link →</a>}
        </div>
      </div>
          ))}
  </section>
</BaseLayout>