---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---
<BaseLayout>
  <div class="page-header">
    <h1>GET /projects</h1>
    <p class="page-subtitle">200 OK · {projects.length} entries</p>
  </div>
  <section class="projects">
    {projects.map((project) => (
      <div class="project">
        <div class="project-id">[{project.id}]</div>
        <h2 class="project-title">{project.title}</h2>
        <p class="project-meta">{project.description}</p>
        <div class="project-stack">
          {project.stack.map((item) => (
            <span class="stack-tag">{item}</span>
          ))}
        </div>
        <div class="project-links">
          {project.demo && <a href={project.demo} class="cta">demo →</a>}
          {project.code && <a href={project.code} class="cta">code →</a>}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>